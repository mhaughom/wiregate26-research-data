{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Kick analysis arcs",
  "type": "object",
  "required": ["taker", "kicks"],
  "properties": {
    "taker": {
      "type": "object",
      "required": ["team", "num"],
      "properties": {"team": {"type": "integer"}, "num": {"type": "integer"}},
      "additionalProperties": false
    },
    "kicks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ts", "t_min", "ours", "apex_m", "dur_s", "s", "z", "traj"],
        "properties": {
          "ts": {"type": "integer"}, "t_min": {"type": "number"},
          "ours": {"type": "boolean"}, "apex_m": {"type": "number"},
          "dur_s": {"type": "number", "exclusiveMinimum": 0},
          "strike_i": {"type": "integer", "minimum": 0},
          "s": {"type": "array", "items": {"type": "number"}},
          "z": {"type": "array", "items": {"type": "number"}},
          "traj": {"$ref": "#/$defs/trajectory"}
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "trajectory": {
      "type": "array",
      "items": {
        "type": "array", "prefixItems": [{"type": "number"}, {"type": "number"}, {"type": "number"}, {"type": "number"}],
        "minItems": 4, "maxItems": 4
      }
    }
  },
  "additionalProperties": false
}
