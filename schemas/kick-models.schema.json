{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Kick physics models",
  "type": "object",
  "required": ["method", "estimates"],
  "properties": {
    "method": {"type": "object"},
    "estimates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ts", "fit", "fit_samples", "fit_rms_m", "cd", "cl", "touchdown_miss_m", "model"],
        "properties": {
          "ts": {"type": "integer"}, "fit": {"type": "string"},
          "fit_samples": {"type": "integer", "minimum": 1},
          "fit_rms_m": {"type": "number", "minimum": 0},
          "cd": {"type": "number"}, "cl": {"type": "number"},
          "touchdown_miss_m": {"type": "number", "minimum": 0},
          "model": {"type": "array"}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
