{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Kick playback tracks",
  "type": "object",
  "required": ["source", "window_s", "tracks"],
  "properties": {
    "source": {"type": "string"},
    "window_s": {"type": "number", "exclusiveMinimum": 0},
    "tracks": {
      "type": "array",
      "items": {
        "type": "object", "required": ["ts", "traj"],
        "properties": {
          "ts": {"type": "integer"},
          "traj": {
            "type": "array",
            "items": {"type": "array", "prefixItems": [{"type": "number"}, {"type": "number"}, {"type": "number"}, {"type": "number"}], "minItems": 4, "maxItems": 4}
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
